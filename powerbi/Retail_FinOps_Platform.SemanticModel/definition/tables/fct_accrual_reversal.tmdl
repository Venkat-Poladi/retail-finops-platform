	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_accrual_reversal'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'fct_accrual_reversal'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(IF(Provider = "", "Unknown", Provider))
			        & "|"
			        & LOWER(IF(BillingAccount = "", "Unknown", BillingAccount))
		isHidden
		lineageTag: f74ce7ef-6554-4326-91e3-5246c5b2ab75
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic


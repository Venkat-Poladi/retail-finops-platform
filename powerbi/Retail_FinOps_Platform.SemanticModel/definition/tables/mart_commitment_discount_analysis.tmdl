	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'mart_commitment_discount_analysis'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'mart_commitment_discount_analysis'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(IF(Provider = "", "Unknown", Provider))
			        & "|"
			        & LOWER(IF(BillingAccount = "", "Unknown", BillingAccount))
		isHidden
		lineageTag: e8b861c0-1e07-45c0-88a3-8b67be93e8a3
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic


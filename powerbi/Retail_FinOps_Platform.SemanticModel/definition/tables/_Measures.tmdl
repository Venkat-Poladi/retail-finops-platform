	measure 'Variance Waterfall Title' =

			VAR BridgeMonthValue =
			    [Variance Bridge Month]
			VAR ChangeAmount =
			    [Variance Current Cost] - [Variance Prior Cost]
			RETURN
			    IF(
			        ISBLANK(BridgeMonthValue),
			        "Month-over-month cost drivers",
			        "Cloud cost "
			            & IF(ChangeAmount >= 0, "increased ", "decreased ")
			            & FORMAT(ABS(ChangeAmount), "$#,##0")
			            & " from "
			            & FORMAT([Variance Prior Cost], "$#,##0")
			            & " to "
			            & FORMAT([Variance Current Cost], "$#,##0")
			            & " in "
			            & FORMAT(BridgeMonthValue, "MMM yyyy")
			    )

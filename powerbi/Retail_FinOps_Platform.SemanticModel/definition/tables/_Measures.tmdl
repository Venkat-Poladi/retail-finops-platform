	measure 'Financial Data Quality Status' =

			VAR InvalidFinancialRows =
			    CALCULATE(
			        COUNTROWS(
			            'fct_cloud_cost'
			        ),
			        'fct_cloud_cost'[is_valid_for_financial_reporting]
			            <> TRUE()
			    )
			VAR NonCanonicalRows =
			    CALCULATE(
			        COUNTROWS(
			            'fct_cloud_cost'
			        ),
			        'fct_cloud_cost'[is_canonical_record]
			            <> TRUE()
			    )
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(
			            [Total Actual Cost]
			        ),
			            "Pending",
			        InvalidFinancialRows > 0
			            || NonCanonicalRows > 0,
			            "Pass with Exceptions",
			        "Pass"
			    )
		displayFolder: Controls
		lineageTag: 50efc983-66ac-44a8-8be5-a07a7e57d833

	measure 'Executive Trend Title' =

			VAR VariancePct = [Budget Variance %]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(VariancePct),
			            "Monthly cloud spend versus budget and forecast",
			        VariancePct > 0,
			            "Cloud spend exceeded budget by "
			                & FORMAT(VariancePct, "0.0%"),
			        VariancePct < 0,
			            "Cloud spend was under budget by "
			                & FORMAT(ABS(VariancePct), "0.0%"),
			        "Cloud spend matched the approved budget"
			    )
		displayFolder: Dynamic Titles
		lineageTag: c7ea5a29-44d9-40f3-bb09-07ac8c45aff5

	measure 'Forecasted Budget' =

			[Total Forecast Cost]
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 3cce98a2-978d-4cd9-8559-c4fee7cdebfe

	measure 'Provider Spend Title' =

			VAR ProviderTable =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            VALUES(dim_provider[provider_name]),
			            "@ProviderCost", [Total Actual Cost]
			        ),
			        [@ProviderCost], DESC,
			        dim_provider[provider_name], ASC
			    )
			VAR TopProvider =
			    MAXX(
			        ProviderTable,
			        dim_provider[provider_name]
			    )
			VAR TopProviderCost =
			    MAXX(
			        ProviderTable,
			        [@ProviderCost]
			    )
			VAR ProviderShare =
			    DIVIDE(
			        TopProviderCost,
			        [Total Actual Cost]
			    )
			RETURN
			    IF(
			        ISBLANK(TopProviderCost),
			        "Cloud spend by provider",
			        TopProvider
			            & " represented "
			            & FORMAT(ProviderShare, "0.0%")
			            & " of cloud spend"
			    )
		displayFolder: Spend
		lineageTag: e9372b03-e25d-43b1-8577-c92cd2900e88

	measure 'Executive Commentary' =


			VAR PortfolioSpend =
			    CALCULATE(
			        [Total Actual Cost],
			        REMOVEFILTERS('dim_date')
			    )

			VAR DepartmentPerformance =
			    FILTER(
			        ADDCOLUMNS(
			            VALUES(
			                'dim_department'[department_name]
			            ),
			            "__Overrun",
			                CALCULATE(
			                    [Total Actual Cost]
			                        - [Total Approved Budget],
			                    REMOVEFILTERS('dim_date')
			                )
			        ),
			        [__Overrun] > 0
			    )

			VAR TopDepartmentRow =
			    TOPN(
			        1,
			        DepartmentPerformance,
			        [__Overrun], DESC,
			        'dim_department'[department_name], ASC
			    )

			VAR TopDepartment =
			    MAXX(
			        TopDepartmentRow,
			        'dim_department'[department_name]
			    )

			VAR TopDepartmentOverrun =
			    MAXX(
			        TopDepartmentRow,
			        [__Overrun]
			    )

			VAR ApplicationSpend =
			    FILTER(
			        ADDCOLUMNS(
			            VALUES(
			                'dim_application'[application_name]
			            ),
			            "__Spend",
			                CALCULATE(
			                    [Total Actual Cost],
			                    REMOVEFILTERS('dim_date')
			                )
			        ),
			        [__Spend] > 0
			    )

			VAR TopTwoApplications =
			    TOPN(
			        2,
			        ApplicationSpend,
			        [__Spend], DESC,
			        'dim_application'[application_name], ASC
			    )

			VAR TopApplicationsText =
			    CONCATENATEX(
			        TopTwoApplications,
			        'dim_application'[application_name],
			        " and ",
			        [__Spend], DESC
			    )

			VAR TopApplicationsSpend =
			    SUMX(
			        TopTwoApplications,
			        [__Spend]
			    )

			VAR TopApplicationsShare =
			    DIVIDE(
			        TopApplicationsSpend,
			        PortfolioSpend,
			        BLANK()
			    )

			VAR AllocationCoverage =
			    CALCULATE(
			        [Allocation Coverage %],
			        REMOVEFILTERS('dim_date')
			    )

			VAR AllocationGap =
			    MAX(
			        0,
			        0.95 - AllocationCoverage
			    )

			VAR DepartmentComment =
			    IF(
			        ISBLANK(TopDepartment),
			        "No department is currently above its approved budget.",
			        TopDepartment
			            & " has the largest budget overrun at "
			            & FORMAT(
			                TopDepartmentOverrun / 1000,
			                "$0.0K"
			            )
			            & "."
			    )

			VAR ApplicationComment =
			    IF(
			        ISBLANK(TopApplicationsText),
			        "Application spend information is unavailable.",
			        TopApplicationsText
			            & " account for "
			            & FORMAT(
			                TopApplicationsShare,
			                "0.0%"
			            )
			            & " of total spend; prioritize these workloads for review."
			    )

			VAR AllocationComment =
			    SWITCH(
			        TRUE(),

			        ISBLANK(AllocationCoverage),
			            "Allocation coverage is unavailable.",

			        AllocationCoverage >= 0.95,
			            "Allocation coverage is "
			                & FORMAT(AllocationCoverage, "0.0%")
			                & ", meeting the 95% target.",

			        "Allocation coverage is "
			            & FORMAT(AllocationCoverage, "0.0%")
			            & "; close the "
			            & FORMAT(AllocationGap, "0.0%")
			            & " gap to the 95% target."
			    )

			RETURN
			    IF(
			        ISBLANK(PortfolioSpend),
			        BLANK(),
			        UNICHAR(8226)
			            & " "
			            & TopDepartment
			            & ": largest budget overrun : "
			            & FORMAT(
			                TopDepartmentOverrun / 1000,
			                "$0.0K"
			            )
			            & UNICHAR(10)

			            & UNICHAR(8226)
			            & " "
			            & TopApplicationsText
			            & ": "
			            & FORMAT(
			                TopApplicationsShare,
			                "0.0%"
			            )
			            & " of total spend : prioritize review"
			            & UNICHAR(10)

			            & UNICHAR(8226)
			            & " Allocation coverage: "
			            & FORMAT(
			                AllocationCoverage,
			                "0.0%"
			            )
			            & " : close the "
			            & FORMAT(
			                AllocationGap * 100,
			                "0.0"
			            )
			            & "-point gap to the 95% target"
			    )
		displayFolder: Executive
		lineageTag: 088c9d5e-aa4c-4864-8ddb-4a3fcc35e313


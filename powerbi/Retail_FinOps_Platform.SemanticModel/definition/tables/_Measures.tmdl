	measure 'Transaction Growth Index' =

			VAR FirstVisibleMonth =
			    MINX(
			        FILTER(
			            ALLSELECTED('dim_date'[month_start_date]),
			            NOT ISBLANK(
			                CALCULATE([Total Transactions])
			            )
			        ),
			        'dim_date'[month_start_date]
			    )
			VAR BaseTransactions =
			    CALCULATE(
			        [Total Transactions],
			        REMOVEFILTERS('dim_date'),
			        TREATAS(
			            { FirstVisibleMonth },
			            'dim_date'[month_start_date]
			        )
			    )
			RETURN
			    DIVIDE(
			        [Total Transactions],
			        BaseTransactions
			    ) * 100
		lineageTag: d6743e61-421b-40f9-ac60-ae2b358b922b


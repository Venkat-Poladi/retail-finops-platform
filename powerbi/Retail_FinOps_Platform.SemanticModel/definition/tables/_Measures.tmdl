	measure 'Actual Cost - Latest Visible Month' =

			VAR LatestMonthWithActual =
			    MAXX(
			        FILTER(
			            ALLSELECTED('dim_date'[month_start_date]),
			            NOT ISBLANK(
			                CALCULATE([Total Actual Cost])
			            )
			        ),
			        'dim_date'[month_start_date]
			    )
			RETURN
			    IF(
			        ISBLANK(LatestMonthWithActual),
			        BLANK(),
			        CALCULATE(
			            [Total Actual Cost],
			            REMOVEFILTERS('dim_date'),
			            TREATAS(
			                { LatestMonthWithActual },
			                'dim_date'[month_start_date]
			            )
			        )
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Forecast
		lineageTag: 4e94e3ea-f430-4109-aa4f-a3ab99fd4ce4

	measure 'Actual Cost - Previous Month' =

			VAR LatestMonthWithActual =
			    MAXX(
			        FILTER(
			            ALLSELECTED('dim_date'[month_start_date]),
			            NOT ISBLANK(
			                CALCULATE([Total Actual Cost])
			            )
			        ),
			        'dim_date'[month_start_date]
			    )
			VAR PrevMonthStart =
			    EDATE(LatestMonthWithActual, -1)
			RETURN
			    IF(
			        ISBLANK(LatestMonthWithActual),
			        BLANK(),
			        CALCULATE(
			            [Total Actual Cost],
			            REMOVEFILTERS('dim_date'),
			            TREATAS(
			                { PrevMonthStart },
			                'dim_date'[month_start_date]
			            )
			        )
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Forecast

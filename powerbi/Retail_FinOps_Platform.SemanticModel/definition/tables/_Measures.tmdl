	measure 'Forecast Cost by Target Month' =

			VAR TargetMonth =
			    SELECTEDVALUE(
			        'dim_date'[month_start_date]
			    )

			VAR ForecastVersionMonth =
			    EDATE(
			        TargetMonth,
			        -1
			    )

			VAR SelectedApplications =
			    VALUES(
			        'dim_application'[application_name]
			    )

			VAR SelectedDepartments =
			    VALUES(
			        'dim_department'[department_name]
			    )

			VAR SelectedProviders =
			    FILTER(
			        VALUES(
			            'dim_provider'[provider_name]
			        ),
			        'dim_provider'[provider_name] IN { "AWS", "GCP" }
			    )

			RETURN
			    IF(
			        ISBLANK(TargetMonth),
			        BLANK(),
			        CALCULATE(
			            SUM(
			                'fct_forecast_version'[forecast_cost]
			            ),

			            REMOVEFILTERS('dim_date'),

			            REMOVEFILTERS(
			                'fct_forecast_version'[forecast_version_month]
			            ),
			            REMOVEFILTERS(
			                'fct_forecast_version'[target_month]
			            ),
			            REMOVEFILTERS(
			                'fct_forecast_version'[application_name]
			            ),
			            REMOVEFILTERS(
			                'fct_forecast_version'[department_name]
			            ),
			            REMOVEFILTERS(
			                'fct_forecast_version'[provider_name]
			            ),

			            TREATAS(
			                { ForecastVersionMonth },
			                'fct_forecast_version'[forecast_version_month]
			            ),
			            TREATAS(
			                { TargetMonth },
			                'fct_forecast_version'[target_month]
			            ),
			            TREATAS(
			                SelectedApplications,
			                'fct_forecast_version'[application_name]
			            ),
			            TREATAS(
			                SelectedDepartments,
			                'fct_forecast_version'[department_name]
			            ),
			            TREATAS(
			                SelectedProviders,
			                'fct_forecast_version'[provider_name]
			            )
			        )
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: ac0d7e80-f23d-445e-aa01-bde40d87f279

	measure 'Forecast Error Month Color' =

			VAR ErrorPct =
			    ABS(
			        [Forecast Error % — Target Month]
			    )

			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(ErrorPct), "#9E9E9E",
			        ErrorPct <= 0.05,  "#2E7D32",
			        ErrorPct <= 0.15,  "#F9A825",
			        "#C62828"
			    )
		lineageTag: 363eab94-a7e9-48ff-9227-1d63bb034b9f


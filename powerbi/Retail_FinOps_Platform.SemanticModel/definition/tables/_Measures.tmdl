	measure 'Forecast Context Label' =

			VAR VersionMonth =
			    [Forecast Version Date]

			VAR FirstTargetMonth =
			    MIN(
			        'fct_forecast_version'[target_month]
			    )

			VAR LastTargetMonth =
			    MAX(
			        'fct_forecast_version'[target_month]
			    )

			VAR TargetPeriodText =
			    SWITCH(
			        TRUE(),

			        ISBLANK(FirstTargetMonth),
			            "No actualized target period",

			        FirstTargetMonth = LastTargetMonth,
			            FORMAT(
			                FirstTargetMonth,
			                "mmm yyyy"
			            ),

			        FORMAT(
			            FirstTargetMonth,
			            "mmm yyyy"
			        )
			            & " to "
			            & FORMAT(
			                LastTargetMonth,
			                "mmm yyyy"
			            )
			    )

			RETURN
			    IF(
			        ISBLANK(VersionMonth),
			        "Select a forecast version",
			        "Backtest: "
			            & FORMAT(
			                VersionMonth,
			                "mmm yyyy"
			            )
			            & " forecast version | Target period: "
			            & TargetPeriodText
			    )
		lineageTag: 0c735066-8447-46cc-97c2-62964fa1504b

	measure 'Forecast MAPE %' =

			VAR ActualizedMonths =
			    FILTER(
			        ADDCOLUMNS(
			            VALUES(
			                'fct_forecast_version'[target_month]
			            ),
			            "@Actual",
			                CALCULATE(
			                    [Actual Cost by Target Month]
			                ),
			            "@Forecast",
			                CALCULATE(
			                    [Forecast Cost by Target Month]
			                )
			        ),
			        NOT ISBLANK([@Actual])
			            && NOT ISBLANK([@Forecast])
			            && [@Actual] <> 0
			    )
			RETURN
			    AVERAGEX(
			        ActualizedMonths,
			        DIVIDE(
			            ABS([@Actual] - [@Forecast]),
			            ABS([@Actual])
			        )
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: QA
		lineageTag: e9c4d179-fedd-4d82-8343-3e747fe8caaa


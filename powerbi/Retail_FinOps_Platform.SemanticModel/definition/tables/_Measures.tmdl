table _Measures
	lineageTag: 81278fa2-52d3-4f3e-84a3-be7b291210dc

	measure 'Total Actual Cost' =

			SUM(
			    'mart_monthly_actuals'[actual_cost]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Spend
		lineageTag: e7961322-eb15-49c9-8b6c-2a9c46dfd6a7

	measure 'Total Approved Budget' =

			SUM('mart_budget'[approved_budget_cost])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Budget
		lineageTag: 18eb53c5-f09e-4453-8aaa-512ad1ee5735

	measure 'Budget Variance' =

			[Total Actual Cost] - [Total Approved Budget]
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Budget
		lineageTag: ca14a831-a98e-45db-a2fc-54286eb17ae6

	measure 'Budget Variance %' =

			DIVIDE(
			    [Budget Variance],
			    [Total Approved Budget]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Budget
		lineageTag: 190d56cf-e1ef-4b45-99b1-43c5bbb70f54

	measure 'Total Unallocated Cost' =

			SUM(
			    'mart_monthly_actuals'[unallocated_cost]
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Allocation
		lineageTag: bf7961ed-e999-4951-85ba-21f5734fd4a5

	measure 'Total Positive Usage Cost' =

			SUM(
			    'mart_monthly_actuals'[positive_usage_cost]
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Allocation
		lineageTag: b22b84a2-fd6c-4b0a-97aa-afbc22b82d43

	measure 'Unallocated Cost %' =

			DIVIDE(
			    [Total Unallocated Cost],
			    [Total Positive Usage Cost],
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Allocation
		lineageTag: 4afa7291-0343-4234-8779-d88cff613fee

	measure 'Total Allocated Cost' =

			[Total Positive Usage Cost] - [Total Unallocated Cost]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Allocation
		lineageTag: 0bf79fdd-8240-4b00-b875-60ce190320c1

	measure 'Allocation Coverage %' =

			DIVIDE(
			    [Total Allocated Cost],
			    [Total Positive Usage Cost],
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Allocation
		lineageTag: 3f23fb2f-d4f1-4574-88ca-c53b2315cf07

	measure 'Total Direct Cost' =


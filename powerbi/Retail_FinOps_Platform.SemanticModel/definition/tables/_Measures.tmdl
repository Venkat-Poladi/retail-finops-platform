		lineageTag: 8f3ad6ec-f900-4a9f-9d32-249e888410a8

	measure 'Identified Savings' =

			CALCULATE(
			    [Net Monthly Savings Identified],
			    KEEPFILTERS(
			        'mart_optimization'[savings_stage]
			            IN {
			                "Identified",
			                "Approved",
			                "Implemented",
			                "Realized"
			            }
			    )
			)
		displayFolder: Savings
		lineageTag: c259d980-fb50-4131-9598-02349340fbf9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Approved Savings' =

			CALCULATE(
			    [Net Monthly Savings Identified],
			    KEEPFILTERS(
			        'mart_optimization'[savings_stage]
			            IN {
			                "Approved",
			                "Implemented",
			                "Realized"
			            }
			    )
			)
		displayFolder: Savings
		lineageTag: 4633946e-a53b-4cc9-bdf4-b3dcee29d29f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Implemented Savings' =

			CALCULATE(
			    [Net Monthly Savings Identified],
			    KEEPFILTERS(
			        'mart_optimization'[savings_stage]
			            IN {
			                "Implemented",
			                "Realized"
			            }
			    )
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Savings
		lineageTag: f3b492d5-7e31-4e3b-aa5f-2d05396d28e5

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Realized Savings %' =

			DIVIDE(
			    [Realized Savings],
			    [Identified Savings],
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Savings
		lineageTag: 01e51b25-5c35-4a13-8e14-e0e6babb6e1d

	measure 'High-Priority Recommendation Count' =

			CALCULATE(
			    [Recommendation Count],
			    KEEPFILTERS(
			        'mart_optimization'[priority] = "HIGH"
			    )
			)
		formatString: 0
		displayFolder: Savings
		lineageTag: fdc45978-97bf-486f-bd75-34bc03926a74

	measure 'Savings Realization Rate %' =

			DIVIDE(
			    [Realized Savings],
			    [Implemented Savings],
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Savings
		lineageTag: d229b60d-d302-42c1-868d-6540cb323c8f

	measure 'Uncovered Eligible Cost' =

			MAX(
			    0,
			    [Commitment Eligible Cost]
			        - [Commitment Covered Cost]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Savings
		lineageTag: 6db6b6b2-c473-4718-b19e-f120e3823148

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Commitment Purchase Cost' =

			SUM(
			    'mart_commitment_discount_analysis'[monthly_commitment_purchase_cost]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Savings
		lineageTag: 3e5556a6-ba44-4790-9350-1066f075f676

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Monthly On-Demand Cost' =

			SUM(
			    'mart_commitment_discount_analysis'[monthly_on_demand_cost]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Savings
		lineageTag: e54c3f6b-4187-46db-95ee-f719b6ed0a74

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Commitment Waste %' =

			DIVIDE(
			    [Underutilized Commitment Cost],
			    [Commitment Purchase Cost],
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Savings
		lineageTag: a3a9ece7-0758-45fe-9015-3a4e51d4401f

	measure 'Commitment Utilization %' =

			DIVIDE(
			    [Commitment Purchase Cost]
			        - [Underutilized Commitment Cost],
			    [Commitment Purchase Cost],
			    0
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Savings
		lineageTag: e456c19f-09f9-438b-a8db-4568281833f9

	measure 'Total Business Activity Units' =

			CALCULATE(
			    SUM(
			        'mart_unit_economics'[transactions]
			    ),
			    'mart_unit_economics'[provider_name] = "ALL_CLOUD"
			)
		displayFolder: Unit Economics
		lineageTag: 208d9dc2-19f9-48ae-9baa-b107c4e00d96

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cost per Business Unit' =

			VAR PortfolioCost =
			    CALCULATE(
			        SUM(
			            'mart_unit_economics'[total_allocated_cost]
			        ),
			        'mart_unit_economics'[provider_name] = "ALL_CLOUD"
			    )
			RETURN
			    DIVIDE(
			        PortfolioCost,
			        [Total Business Activity Units],
			        0
			    )
		formatString: \$#,0.0000;(\$#,0.0000);\$#,0.0000
		displayFolder: Unit Economics
		lineageTag: 0ca3af7d-bace-4ea8-afe1-de59f5784f01

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Cost per Transaction' =

			DIVIDE (
			    [Unit Economics Cost],
			    [Total Transactions]
			)
		formatString: \$#,0.0000;(\$#,0.0000);\$#,0.0000
		displayFolder: Unit Economics
		lineageTag: 6876c2e1-262d-4a9f-86eb-f38732477195

	measure 'Cost per Customer' =

			VAR PortfolioCost =
			    CALCULATE(
			        SUM(
			            'mart_unit_economics'[total_allocated_cost]
			        ),
			        'mart_unit_economics'[provider_name] = "ALL_CLOUD"
			    )
			VAR ActiveCustomerMonths =
			    CALCULATE(
			        SUM(
			            'mart_unit_economics'[average_daily_active_customers]
			        ),
			        'mart_unit_economics'[provider_name] = "ALL_CLOUD"
			    )
			RETURN
			    DIVIDE(
			        PortfolioCost,
			        ActiveCustomerMonths,
			        0
			    )
		formatString: 0.0000
		displayFolder: Unit Economics
		lineageTag: 00a733b0-5b68-4c9e-ad49-e8aa5a4bbac8

	measure 'Unit Cost Month-over-Month Change %' =

			VAR CurrentUnitCost =
			    [Cost per Transaction]
			VAR PreviousUnitCost =
			    CALCULATE(
			        [Cost per Transaction],
			        DATEADD(
			            'dim_date'[full_date],
			            -1,
			            MONTH
			        )
			    )
			RETURN
			    DIVIDE(
			        CurrentUnitCost - PreviousUnitCost,
			        PreviousUnitCost,
			        0
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit Economics
		lineageTag: 1112b064-7218-45ba-98b1-41483a9b307c

	measure 'Business Activity Growth %' =

			VAR CurrentActivity =
			    [Total Business Activity Units]
			VAR PrevActivity =
			    CALCULATE(
			        [Total Business Activity Units],
			        DATEADD(
			            'dim_date'[full_date],
			            -1,
			            MONTH
			        )
			    )
			RETURN
			    IF(
			        ISBLANK(CurrentActivity)
			            || ISBLANK(PrevActivity)
			            || PrevActivity = 0,
			        BLANK(),
			        DIVIDE(
			            CurrentActivity - PrevActivity,
			            PrevActivity
			        )
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit Economics
		lineageTag: 9454c858-ff68-4574-931d-96306e0c1466

	measure 'Unit Economics Efficiency Change %' =

			VAR CurrentUnitCost =
			    [Cost per Transaction]
			VAR PreviousUnitCost =
			    CALCULATE(
			        [Cost per Transaction],
			        DATEADD(
			            'dim_date'[full_date],
			            -1,
			            MONTH
			        )
			    )
			RETURN
			    DIVIDE(
			        PreviousUnitCost - CurrentUnitCost,
			        PreviousUnitCost,
			        0
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Unit Economics
		lineageTag: dd424f48-a0aa-47ef-8925-e0f352c711cc

	measure 'Cost Growth %' =

			VAR CurrentCost =
			    [Total Actual Cost]
			VAR PrevCost =
			    CALCULATE(
			        [Total Actual Cost],
			        DATEADD(
			            'dim_date'[full_date],
			            -1,
			            MONTH
			        )
			    )
			RETURN
			    IF(
			        ISBLANK(CurrentCost)
			            || ISBLANK(PrevCost)
			            || PrevCost = 0,
			        BLANK(),
			        DIVIDE(
			            CurrentCost - PrevCost,
			            PrevCost
			        )
			    )
		formatString: 0.0
		displayFolder: Savings
		lineageTag: 130d4f7f-9b5d-41e8-8ab3-9c0ea3aff36f

	measure 'Month-over-Month Cost Change' =

			VAR PreviousMonthCost =
			    CALCULATE(
			        [Total Actual Cost],
			        DATEADD(
			            'dim_date'[full_date],
			            -1,
			            MONTH
			        )
			    )
			RETURN
			    [Total Actual Cost] - PreviousMonthCost
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Spend
		lineageTag: 7babb7e9-d57d-4a9b-ba07-0ea86e5c6044

	measure 'Month-over-Month Cost Change %' =

			VAR PreviousMonthCost =
			    CALCULATE(
			        [Total Actual Cost],
			        DATEADD(
			            'dim_date'[full_date],
			            -1,
			            MONTH
			        )
			    )
			RETURN
			    DIVIDE(
			        [Total Actual Cost] - PreviousMonthCost,
			        PreviousMonthCost,
			        0
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Spend
		lineageTag: 1c7d967f-b5e8-4e75-9f3d-460855dc3585

	measure 'Year-to-Date Actual Cost' =

			TOTALYTD(
			    [Total Actual Cost],
			    'dim_date'[full_date]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Unit Economics
		lineageTag: 90382a33-a151-4ea4-b91b-124474e45a2c

	measure 'Total Forecast Cost' =

			VAR VersionToUse =
			    [Forecast Version Date]
			RETURN
			    IF(
			        ISBLANK(VersionToUse),
			        BLANK(),
			        CALCULATE(
			            SUM(
			                'fct_forecast_version'[forecast_cost]
			            ),
			            REMOVEFILTERS(
			                'fct_forecast_version'[forecast_version_month]
			            ),
			            'fct_forecast_version'[forecast_version_month]
			                = VersionToUse
			        )
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Forecast
		lineageTag: a6a3f295-52ae-4ea1-af81-79e9a6a7f777

	measure 'Forecast Variance' =

			VAR ActualCost =
			    [Forecast Actual Cost]
			VAR ForecastCost =
			    [Forecast Cost - Actualized Periods]
			RETURN
			    IF(
			        ISBLANK(ActualCost)
			            || ISBLANK(ForecastCost),
			        BLANK(),
			        ActualCost - ForecastCost
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Forecast
		lineageTag: b6e3cbaa-b707-41ce-8c08-8dc1ecb3c9e7

	measure 'Forecast Variance %' =

			DIVIDE(
			    [Forecast Variance],
			    [Forecast Actual Cost],
			    BLANK()
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Forecast
		lineageTag: 87fa7d95-b31b-4345-af21-2b4f3671427d

	measure 'Forecast Accuracy %' =

			VAR ActualCost =
			    ABS(
			        [Forecast Actual Cost]
			    )
			VAR AccuracyPct =
			    1
			        - DIVIDE(
			            [Absolute Forecast Error],
			            ActualCost,
			            BLANK()
			        )
			RETURN
			    IF(
			        ISBLANK(ActualCost)
			            || ActualCost = 0,
			        BLANK(),
			        MIN(
			            1,
			            MAX(
			                0,
			                AccuracyPct
			            )
			        )
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Forecast
		lineageTag: 5871681b-fef7-4bc6-8182-2aff3bf2ae02

	measure 'Absolute Forecast Error' =

			VAR VersionToUse =
			    [Forecast Version Date]
			RETURN
			    IF(
			        ISBLANK(VersionToUse),
			        BLANK(),
			        CALCULATE(
			            SUMX(
			                FILTER(
			                    'fct_forecast_version',
			                    NOT ISBLANK(
			                        'fct_forecast_version'[actual_cost]
			                    )
			                        &&
			                    NOT ISBLANK(
			                        'fct_forecast_version'[forecast_cost]
			                    )
			                ),
			                ABS(
			                    'fct_forecast_version'[actual_cost]
			                        -
			                    'fct_forecast_version'[forecast_cost]
			                )
			            ),
			            REMOVEFILTERS(
			                'fct_forecast_version'[forecast_version_month]
			            ),
			            'fct_forecast_version'[forecast_version_month]
			                = VersionToUse
			        )
			    )
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Forecast
		lineageTag: 2df322d6-8cff-40da-99b6-417a4b92c3f2

	measure 'Forecast Bias %' =

			VAR ActualCost =
			    [Forecast Actual Cost]
			VAR ForecastCost =
			    [Forecast Cost - Actualized Periods]
			RETURN
			    DIVIDE(
			        ForecastCost - ActualCost,
			        ActualCost,
			        BLANK()
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Forecast
		lineageTag: e58d444e-9fd5-4061-ac81-9993ef12ab1f

	measure 'Total Accrued Cost' =

			SUM(
			    'fct_cloud_accrual'[accrual_amount]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Controls
		lineageTag: ee13fb1d-66cc-4ba7-9d09-5fe11d78345b

	measure 'Total Reversed Accrual Cost' =

			ABS(
			    SUM(
			        'fct_accrual_reversal'[reversal_amount]
			    )
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Controls
		lineageTag: 03025247-e493-42aa-be4e-33d598830f42

	measure 'Outstanding Accrual Balance' =

			[Total Accrued Cost]
			    - [Total Reversed Accrual Cost]
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Controls
		lineageTag: 51091930-b1ba-4226-8d9c-91e7ec333349

	measure 'Reclassification Amount' =

			SUM(
			    'fct_reclass_journal'[journal_amount]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Controls
		lineageTag: 14f05370-81a7-426b-9ee7-ae53cb237205

	/// Controls
	///
	measure 'Chargeback Journal Amount' =

			SUM(
			    'fct_chargeback_journal'[journal_amount]
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Controls

	/// Controls
	measure 'Close Checklist Completion %' =

			VAR TotalTasks =
			    COUNTROWS(
			        'mart_close_checklist'
			    )
			VAR CompletedTasks =
			    CALCULATE(
			        COUNTROWS(
			            'mart_close_checklist'
			        ),
			        FILTER(
			            'mart_close_checklist',
			            UPPER(
			                TRIM(
			                    COALESCE(
			                        'mart_close_checklist'[status],
			                        ""
			                    )
			                )
			            )
			                IN {
			                    "COMPLETE",
			                    "COMPLETED"
			                }
			        )
			    )
			RETURN
			    DIVIDE(
			        CompletedTasks,
			        TotalTasks,
			        0
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Controls
		lineageTag: d2486761-8957-40f1-8483-36a2162b7682

	measure 'Overdue Close Task Count' =

			CALCULATE(
			    COUNTROWS(
			        'mart_close_checklist'
			    ),
			    FILTER(
			        'mart_close_checklist',
			        'mart_close_checklist'[due_date] < TODAY()
			            &&
			        NOT(
			            UPPER(
			                TRIM(
			                    COALESCE(
			                        'mart_close_checklist'[status],
			                        ""
			                    )
			                )
			            )
			                IN {
			                    "COMPLETE",
			                    "COMPLETED"
			                }
			        )

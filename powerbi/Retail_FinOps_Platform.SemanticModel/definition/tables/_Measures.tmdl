	measure 'Total Transactions' =

			VAR SelectedProvider =
			    SELECTEDVALUE ( 'dim_provider'[provider_name] )

			VAR HasOneProvider =
			    HASONEVALUE ( 'dim_provider'[provider_name] )

			VAR IsSupportedProvider =
			    SelectedProvider = "AWS"
			        || SelectedProvider = "GCP"

			VAR ProviderScope =
			    IF (
			        HasOneProvider && IsSupportedProvider,
			        SelectedProvider,
			        "ALL_CLOUD"
			    )

			RETURN
			    IF (
			        HasOneProvider && NOT ( IsSupportedProvider ),
			        BLANK (),
			        CALCULATE (
			            SUM ( 'mart_unit_economics'[transactions] ),
			            REMOVEFILTERS ( 'mart_unit_economics'[provider_name] ),
			            TREATAS (
			                { ProviderScope },
			                'mart_unit_economics'[provider_name]

			RETURN
			    SWITCH(
			        TRUE(),

			        SelectedMetric = "Coverage" &&
			            MetricValue >= 0.80, "#2E7D32",
			        SelectedMetric = "Coverage" &&
			            MetricValue >= 0.60, "#F9A825",
			        SelectedMetric = "Coverage", "#C62828",

			        SelectedMetric = "Utilization" &&

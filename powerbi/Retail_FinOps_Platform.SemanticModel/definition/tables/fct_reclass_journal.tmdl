	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_reclass_journal'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'fct_reclass_journal'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(IF(Provider = "", "Unknown", Provider))
			        & "|"
			        & LOWER(IF(BillingAccount = "", "Unknown", BillingAccount))
		isHidden
		lineageTag: 3ddeacea-6c03-4596-a767-03c652ac7dcc
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic


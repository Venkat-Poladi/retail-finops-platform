	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_chargeback_journal'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'fct_chargeback_journal'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(IF(Provider = "", "Unknown", Provider))
			        & "|"
			        & LOWER(IF(BillingAccount = "", "Unknown", BillingAccount))
		isHidden
		lineageTag: 2356792a-79b2-49cb-a360-8425bde508cd
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic


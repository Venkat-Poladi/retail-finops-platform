	column Column
		type: calculated
		lineageTag: 1a9351e6-61c1-4ff9-997b-ebdb97b091d9
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	column 'Service Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_cloud_cost'[provider_name],
			            ""
			        )
			    )
			VAR Service =
			    TRIM(
			        COALESCE(
			            'fct_cloud_cost'[service_name],
			            ""
			        )
			    )
			RETURN
			    UPPER(
			        IF(
			            Provider = "",
			            "Unknown",
			            Provider
			        )
			    )
			        & "|"
			        & LOWER(
			            IF(
			                Service = "",
			                "Unknown",
			                Service
			            )
			        )
		lineageTag: 7777a1c1-2707-4b70-96ae-1e88475dd80a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_cloud_cost'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'fct_cloud_cost'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(
			        IF(
			            Provider = "",
			            "Unknown",
			            Provider
			        )
			    )
			        & "|"
			        & LOWER(
			            IF(
			                BillingAccount = "",
			                "Unknown",
			                BillingAccount
			            )
			        )
		lineageTag: 6021ebaa-9985-486d-acdf-379910063c2d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic


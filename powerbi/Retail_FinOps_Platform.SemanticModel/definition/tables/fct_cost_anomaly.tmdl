	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_cost_anomaly'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'fct_cost_anomaly'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(
			        IF(Provider = "", "Unknown", Provider)
			    )
			        & "|"
			        & LOWER(
			            IF(BillingAccount = "", "Unknown", BillingAccount)
			        )
		isHidden
		lineageTag: 22332e81-9dd6-4a7f-8a4c-f9c08fa3a6e5
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Service Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_cost_anomaly'[provider_name],
			            ""
			        )
			    )
			VAR Service =
			    TRIM(
			        COALESCE(
			            'fct_cost_anomaly'[service_name],
			            ""
			        )
			    )
			RETURN
			    UPPER(
			        IF(Provider = "", "Unknown", Provider)
			    )
			        & "|"
			        & LOWER(
			            IF(Service = "", "Unknown", Service)
			        )
		isHidden
		lineageTag: c1587e0f-8812-416c-a1ce-4c5336009c58
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic


	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'mart_optimization'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'mart_optimization'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(
			        IF(
			            Provider = "",
			            "Unknown",
			            Provider
			        )
			    )
			        & "|"
			        & LOWER(
			            IF(
			                BillingAccount = "",
			                "Unknown",
			                BillingAccount
			            )
			        )
		lineageTag: 1fcf8cb6-43e5-469f-9953-6f7f03644e60
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Service Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'mart_optimization'[provider_name],
			            ""
			        )
			    )
			VAR Service =
			    TRIM(
			        COALESCE(
			            'mart_optimization'[service_name],
			            ""
			        )
			    )
			RETURN
			    UPPER(IF(Provider = "", "Unknown", Provider))
			        & "|"
			        & LOWER(IF(Service = "", "Unknown", Service))
		lineageTag: 142cd39c-52c0-40d4-baa0-800e87cb926f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Optimization Action Label' =

			VAR ApplicationText =
			    COALESCE(
			        'mart_optimization'[application_name],
			        "Unknown"
			    )
			VAR CategoryText =
			    COALESCE(
			        'mart_optimization'[recommendation_category],
			        "Optimization"
			    )
			RETURN
			    ApplicationText
			        & " — "
			        & CategoryText
		lineageTag: da18fb65-b2a3-4488-b8f9-b98bfcca56c3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Optimization Action Short' =

			VAR RecommendationText =
			    LOWER(
			        COALESCE(
			            'mart_optimization'[recommendation],
			            ""
			        )
			    )

			VAR ShortAction =
			    SWITCH(
			        TRUE(),

			        CONTAINSSTRING(RecommendationText, "log retention"),
			            "Reduce log retention",

			        CONTAINSSTRING(RecommendationText, "storage lifecycle"),
			            "Apply storage lifecycle",

			        CONTAINSSTRING(RecommendationText, "unattached"),
			            "Remove unattached storage",

			        CONTAINSSTRING(RecommendationText, "idle"),
			            "Eliminate idle resources",

			        CONTAINSSTRING(RecommendationText, "rightsize"),
			            "Rightsize compute",

			        CONTAINSSTRING(RecommendationText, "nat gateway"),
			            "Review NAT gateway usage",

			        CONTAINSSTRING(RecommendationText, "commitment"),
			            "Expand commitment coverage",

			        CONTAINSSTRING(RecommendationText, "reserved"),
			            "Increase reserved coverage",

			        CONTAINSSTRING(RecommendationText, "savings plan"),
			            "Purchase Savings Plans",

			        CONTAINSSTRING(RecommendationText, "schedule"),
			            "Schedule nonproduction shutdown",

			        CONTAINSSTRING(RecommendationText, "tier"),
			            "Move to lower-cost tier",

			        COALESCE(
			            'mart_optimization'[recommendation_category],
			            "Review optimization"
			        )
			    )

			RETURN
			    COALESCE(
			        'mart_optimization'[application_name],
			        "Unknown application"
			    )
			        & " — "
			        & ShortAction
		lineageTag: bd9796a6-946b-4782-adef-b281eb629261
		summarizeBy: none

		annotation SummarizationSetBy = Automatic


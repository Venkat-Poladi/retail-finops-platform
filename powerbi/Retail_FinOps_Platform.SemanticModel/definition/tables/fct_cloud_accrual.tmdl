	column 'Billing Account Key' =

			VAR Provider =
			    TRIM(
			        COALESCE(
			            'fct_cloud_accrual'[provider_name],
			            ""
			        )
			    )
			VAR BillingAccount =
			    TRIM(
			        COALESCE(
			            'fct_cloud_accrual'[billing_account_id],
			            ""
			        )
			    )
			RETURN
			    UPPER(IF(Provider = "", "Unknown", Provider))
			        & "|"
			        & LOWER(IF(BillingAccount = "", "Unknown", BillingAccount))
		isHidden
		lineageTag: 87e80cda-d64f-49d7-8368-367ab324aa99
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

